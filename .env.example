# Django Environment Variables Template
# Copy this file to .env and fill in the actual values

# ============================================================================
# SERVICE AUTHENTICATION KEYS (CRITICAL - Keep these secret!)
# ============================================================================
# All services need ALL three keys to validate each other
DJANGO_SERVICE_KEY=sk_django_oOcCi1SfeOtcAY3q5iuH-xzulCnwunYeedAZUFEinNc
FASTAPI_SERVICE_KEY=sk_fastapi_9DoPMGmd4I-5HhX_d68me-A_rwjhz_FANd1M0dIeV6k
NODEJS_SERVICE_KEY=sk_nodejs_mA-XH9BJLiDlmXjA9vGa7XgczT68v3CoQNrcvEx0s34

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# IMPORTANT: Must be the SAME across ALL services (Django, FastAPI, Node.js)
JWT_SECRET=your-shared-jwt-secret-key-change-this-in-production-make-it-long-and-random
JWT_ALGORITHM=HS256

# ============================================================================
# DJANGO SETTINGS
# ============================================================================
SECRET_KEY=django-insecure-change-this-to-a-long-random-string-for-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_NAME=whatsapp_django
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# For Azure/Production
# DB_HOST=your-database-server.postgres.database.azure.com
# DB_SSL_MODE=require

# ============================================================================
# SERVICE URLs (for making cross-service API calls)
# ============================================================================
DJANGO_URL=http://localhost:8000
FASTAPI_URL=http://localhost:8001
NODEJS_URL=http://localhost:3000

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Celery Broker
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# EMAIL CONFIGURATION (if using email features)
# ============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=no-reply@nuren.ai
PASSWORD_RESET_URL=https://nuren.ai/reset-password
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=2

# ============================================================================
# WHATSAPP / META CONFIGURATION
# ============================================================================
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
META_APP_SECRET=your_meta_app_secret

# ============================================================================
# GOOGLE CONFIGURATION (if using Google services)
# ============================================================================
GOOGLE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json

# ============================================================================
# OPENAI CONFIGURATION (if using AI features)
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# AZURE STORAGE (if using Azure Blob Storage)
# ============================================================================
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_STORAGE_CONTAINER=media

# ============================================================================
# CORS Configuration
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# NOTES
# ============================================================================
# 1. NEVER commit .env file to git
# 2. All service keys must be the same across all services
# 3. JWT_SECRET must be the same across all services
# 4. Rotate service keys quarterly for security
# 5. Use strong, random values for production
# 6. For production, set DEBUG=False and update ALLOWED_HOSTS
